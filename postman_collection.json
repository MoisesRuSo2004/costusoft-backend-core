    {
      "name": "📦 PEDIDOS",
      "item": [
        {
          "name": "1️⃣ Crear pedido (BORRADOR)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"colegioId\": 1,\n  \"fechaEstimadaEntrega\": \"2026-05-15\",\n  \"observaciones\": \"Pedido urgente para evento escolar\",\n  \"detalles\": [\n    {\n      \"uniformeId\": 1,\n      \"cantidad\": 50,\n      \"talla\": \"M\"\n    },\n    {\n      \"uniformeId\": 2,\n      \"cantidad\": 50,\n      \"talla\": \"M\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/pedidos",
              "host": ["{{baseUrl}}"],
              "path": ["api", "pedidos"]
            },
            "description": "Crea un nuevo pedido en estado BORRADOR.\nPuede especificar un colegio existente (colegioId) o crear uno nuevo (nuevoColegio).\nRetorna: id del pedido, numeroPedido (PED-2026-00001), estado=BORRADOR."
          },
          "response": []
        },
        {
          "name": "1️⃣ Crear pedido (con colegio NEW — inline)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nuevoColegio\": {\n    \"nombre\": \"Colegio Santa María\",\n    \"direccion\": \"Calle 5 #123\"\n  },\n  \"fechaEstimadaEntrega\": \"2026-06-01\",\n  \"observaciones\": \"Nuevo cliente, pedido inicial\",\n  \"detalles\": [\n    {\n      \"uniformeId\": 1,\n      \"cantidad\": 30,\n      \"talla\": \"S\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/pedidos",
              "host": ["{{baseUrl}}"],
              "path": ["api", "pedidos"]
            },
            "description": "Crear pedido CON COLEGIO NUEVO inline (si no existe).\nSi el nombre ya existe, rechaza con error 409 Conflict.\nSi es nuevo, lo crea y vincula al pedido en la misma transacción."
          },
          "response": []
        },
