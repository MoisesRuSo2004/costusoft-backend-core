    {
      "name": "📊 CALCULADORA",
      "item": [
        {
          "name": "1️⃣ Verificar una prenda (POST)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"uniformeId\": 1,\n  \"cantidad\": 50\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/calculadora/verificar",
              "host": ["{{baseUrl}}"],
              "path": ["api", "calculadora", "verificar"]
            },
            "description": "Verifica si hay stock suficiente para fabricar 50 unidades del uniforme ID 1.\nRespuesta incluye: disponible, cantidadMaximaFabricable, detalles por insumo."
          },
          "response": []
        },
        {
          "name": "2️⃣ Verificar una prenda (GET — conveniente)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/calculadora/verificar/1?cantidad=50",
              "host": ["{{baseUrl}}"],
              "path": ["api", "calculadora", "verificar", "1"],
              "query": [
                {
                  "key": "cantidad",
                  "value": "50"
                }
              ]
            },
            "description": "Mismo que POST /verificar pero sin body — útil para Swagger/Postman."
          },
          "response": []
        },
        {
          "name": "3️⃣ Calcular pedido (Modo A — colegio + cantidad)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"colegioId\": 1,\n  \"cantidad\": 50\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/calculadora/pedido",
              "host": ["{{baseUrl}}"],
              "path": ["api", "calculadora", "pedido"]
            },
            "description": "Modo A: Fabrica 50 unidades de TODAS las prendas relacionadas al colegio 1.\nConsolida insumos compartidos y retorna factorCumplimiento, insumoLimitante, resumenInsumos[]."
          },
          "response": []
        },
        {
          "name": "4️⃣ Calcular pedido (Modo B — lista explícita)",
