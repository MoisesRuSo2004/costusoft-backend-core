                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                }
              ]
            },
            "description": "Filtra pedidos por estado. Estados válidos:\n- BORRADOR, CALCULADO, CONFIRMADO, EN_PRODUCCION, LISTO_PARA_ENTREGA, ENTREGADO, CANCELADO"
          },
          "response": []
        },
