            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fecha\": \"2026-04-09\",\n  \"descripcion\": \"Compra mensual de telas — actualizado\",\n  \"proveedorId\": {{proveedorId}},\n  \"detalles\": [\n    {\n      \"insumoId\": {{insumoId}},\n      \"cantidad\": 250\n    }\n  ]\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/entradas/{{entradaId}}", "host": ["{{baseUrl}}"], "path": ["api","entradas","{{entradaId}}"] }
          }
        },
