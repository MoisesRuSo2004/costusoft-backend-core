{
  "info": {
    "name": "Costusoft — Inventory System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Colección completa del API REST del sistema de inventario de Costusoft. Incluye todos los módulos: Auth, Usuarios, Insumos, Colegios, Proveedores, Entradas, Salidas, Uniformes, Pedidos, Calculadora, Dashboard, Reportes y Predicción."
  },
  "variable": [
    { "key": "baseUrl",       "value": "http://localhost:8080",  "type": "string" },
    { "key": "accessToken",   "value": "",                       "type": "string" },
    { "key": "refreshToken",  "value": "",                       "type": "string" },
    { "key": "insumoId",      "value": "1",                      "type": "string" },
    { "key": "colegioId",     "value": "1",                      "type": "string" },
    { "key": "proveedorId",   "value": "1",                      "type": "string" },
    { "key": "uniformeId",    "value": "1",                      "type": "string" },
    { "key": "pedidoId",      "value": "1",                      "type": "string" },
    { "key": "entradaId",     "value": "1",                      "type": "string" },
    { "key": "salidaId",      "value": "1",                      "type": "string" },
    { "key": "usuarioId",     "value": "1",                      "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [

    {
      "name": "01 — Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data) {",
                  "  pm.collectionVariables.set('accessToken',  res.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "  console.log('Tokens guardados. Rol:', res.data.usuario.rol);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data) {",
                  "  pm.collectionVariables.set('accessToken',  res.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/refresh", "host": ["{{baseUrl}}"], "path": ["api","auth","refresh"] }
          }
        },
        {
          "name": "Mi perfil (GET /auth/me)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/auth/me", "host": ["{{baseUrl}}"], "path": ["api","auth","me"] }
          }
        }
      ]
    },

    {
      "name": "02 — Usuarios (ADMIN)",
      "item": [
        {
          "name": "Listar usuarios",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/usuarios?page=0&size=10&sortBy=username&sortDir=asc",
              "host": ["{{baseUrl}}"], "path": ["api","usuarios"],
              "query": [
                { "key": "page",    "value": "0" },
                { "key": "size",    "value": "10" },
                { "key": "sortBy",  "value": "username" },
                { "key": "sortDir", "value": "asc" }
              ]
            }
          }
        },
        {
          "name": "Obtener usuario por ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/usuarios/{{usuarioId}}", "host": ["{{baseUrl}}"], "path": ["api","usuarios","{{usuarioId}}"] }
          }
        },
        {
          "name": "Crear usuario",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"bodeguero01\",\n  \"password\": \"pass1234\",\n  \"correo\": \"bodeguero01@costusoft.com\",\n  \"rol\": \"BODEGA\",\n  \"activo\": true\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/usuarios", "host": ["{{baseUrl}}"], "path": ["api","usuarios"] }
          }
        },
        {
          "name": "Actualizar usuario",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"bodeguero01\",\n  \"password\": \"newpass456\",\n  \"correo\": \"bodeguero01@costusoft.com\",\n  \"rol\": \"USER\",\n  \"activo\": true\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/usuarios/{{usuarioId}}", "host": ["{{baseUrl}}"], "path": ["api","usuarios","{{usuarioId}}"] }
          }
        },
        {
          "name": "Toggle activo/inactivo",
          "request": {
            "method": "PATCH",
            "url": { "raw": "{{baseUrl}}/api/usuarios/{{usuarioId}}/toggle", "host": ["{{baseUrl}}"], "path": ["api","usuarios","{{usuarioId}}","toggle"] }
          }
        },
        {
          "name": "Cambiar mi contraseña",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"passwordActual\": \"admin123\",\n  \"passwordNueva\": \"nuevoPass99\",\n  \"passwordConfirmacion\": \"nuevoPass99\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/usuarios/mi-password", "host": ["{{baseUrl}}"], "path": ["api","usuarios","mi-password"] }
          }
        },
        {
          "name": "Eliminar usuario",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/usuarios/{{usuarioId}}", "host": ["{{baseUrl}}"], "path": ["api","usuarios","{{usuarioId}}"] }
          }
        }
      ]
    },

