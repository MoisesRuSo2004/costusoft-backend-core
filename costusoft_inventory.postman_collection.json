            "url": { "raw": "{{baseUrl}}/api/entradas/{{entradaId}}/rechazar", "host": ["{{baseUrl}}"], "path": ["api","entradas","{{entradaId}}","rechazar"] }
          }
        },
        {
          "name": "Eliminar entrada (ADMIN — solo PENDIENTE)",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/entradas/{{entradaId}}", "host": ["{{baseUrl}}"], "path": ["api","entradas","{{entradaId}}"] }
          }
        }
      ]
