              "raw": "{{baseUrl}}/api/entradas/estado?estado=PENDIENTE&page=0&size=10",
              "host": ["{{baseUrl}}"], "path": ["api","entradas","estado"],
              "query": [
                { "key": "estado", "value": "PENDIENTE", "description": "PENDIENTE | CONFIRMADO | RECHAZADO" },
                { "key": "page",   "value": "0" },
                { "key": "size",   "value": "10" }
